generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String
  role           String?
  approved       Boolean   @default(false)
  specialisatie  String?
  ervaring       String?
  certificaat    String?
  credits        Int       @default(0)
  rating         Int       @default(0)
  createdAt      DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  sporterRequests HelpRequest[] @relation("SporterRequests")
  trainerRequests HelpRequest[] @relation("TrainerRequests")

  sentMessages Message[] @relation("UserMessages")

  payments Payment[]
  invoiceInfos InvoiceInfo[]
}

model HelpRequest {
  id              String   @id @default(cuid())
  sporterId       String
  trainerId       String
  description     String
  video           String?
  allowAiTraining Boolean  @default(false)
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  sporter User @relation("SporterRequests", fields: [sporterId], references: [id])
  trainer User @relation("TrainerRequests", fields: [trainerId], references: [id])

  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  requestId String
  senderId  String
  content   String
  videoUrl  String?
  createdAt DateTime @default(now())

  request HelpRequest @relation(fields: [requestId], references: [id])
  sender  User        @relation("UserMessages", fields: [senderId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InvoiceInfo {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  fullName     String
  companyName  String?
  street       String
  postalCode   String
  city         String
  country      String
  vatNumber    String?
  phone        String?
  email        String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments     Payment[]
}

model Payment {
  id             String       @id @default(cuid())
  mollieId       String       @unique
  amount         String
  description    String
  status         String
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id])
  userId         String

  invoiceInfo    InvoiceInfo? @relation(fields: [invoiceInfoId], references: [id])
  invoiceInfoId  String?
}
